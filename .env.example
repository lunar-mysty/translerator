OPENROUTER_API_KEY=your-api-key-here

# Optional: where request-limit usage data is stored.
# Relative paths resolve from the project root.
TRANSLERATOR_RATE_LIMIT_STORE_PATH=data/request-limits.json

# Optional: where redeemable credit code definitions are stored.
# Relative paths resolve from the project root. This file should stay private.
TRANSLERATOR_CREDIT_CODE_FILE_PATH=data/credit-codes.json

# Credit code file format:
# {
#   "codes": {
#     "BONUS-100": {
#       "credits": { "fast": 100, "precise": 50, "super": 25 },
#       "redemptionMode": "global",
#       "expiresAt": 1798761600,
#       "message": "Bonus credits added."
#     },
#     "PER-DEVICE": {
#       "credits": { "fast": 25 },
#       "redemptionMode": "identity"
#     },
#     "FOREVER": {
#       "credits": { "fast": 10 },
#       "redemptionMode": "unlimited"
#     }
#   }
# }

# Optional: change this before production use to make stored limiter hashes installation-specific.
TRANSLERATOR_RATE_LIMIT_HASH_SALT=change-this-local-secret
